{
  "name": "@growthos/mcp-headless-example",
  "version": "0.0.0",
  "private": true,
  "description": "Runnable example: a headless agent that talks to a GrowthOS project over MCP (KAN-78).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "growthos-mcp-weekly-digest": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@growthos/eslint-config": "workspace:*",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
