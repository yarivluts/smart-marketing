{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalPassThroughEnv": [
    "HTTPS_PROXY",
    "https_proxy",
    "HTTP_PROXY",
    "http_proxy",
    "NO_PROXY",
    "no_proxy",
    "PIP_CERT",
    "SSL_CERT_FILE",
    "REQUESTS_CA_BUNDLE",
    "CURL_CA_BUNDLE",
    "NODE_EXTRA_CA_CERTS",
    "GIT_SSL_CAINFO",
    "NODE_USE_ENV_PROXY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "@growthos/web#test": {
      "dependsOn": ["^build", "@growthos/firebase-orm-models#test"]
    },
    "@growthos/api#test": {
      "dependsOn": ["^build", "@growthos/firebase-orm-models#test"]
    },
    "@growthos/firebase-orm-models#test": {
      "dependsOn": ["^build", "@growthos/dbt-transform#test"]
    },
    "@growthos/dbt-transform#build": {
      "outputs": ["dbt/target/**"]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
