{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "@growthos/web#test": {
      "dependsOn": ["^build", "@growthos/firebase-orm-models#test"]
    },
    "@growthos/api#test": {
      "dependsOn": ["^build", "@growthos/firebase-orm-models#test"]
    },
    "@growthos/dbt-transform#build": {
      "outputs": ["dbt/target/**"]
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
