# Firebase client SDK config (browser-exposed). Get these from the Firebase
# console once KAN-18 provisions a real project; safe to leave unset for local
# dev/test, which falls back to the same "demo-growthos-test" emulator project
# used by packages/firebase-orm-models.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Set only for local dev against the Firebase Auth emulator (`pnpm --filter
# @growthos/web test` starts one automatically for tests). Format: "host:port".
NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# Firebase Admin SDK (server-only). Required in production; unset falls back
# to unauthenticated emulator-only mode.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Matched by the Admin SDK automatically when set (same value as above).
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# Base URL of the GrowthOS ingest API (apps/api's `/v1/ingest`, KAN-32),
# browser-exposed so the KAN-57 touchpoint-capture embed snippet/tracker can
# post directly to it. Falls back to a local-dev default when unset.
NEXT_PUBLIC_INGEST_API_URL=http://localhost:3001/v1/ingest

# Base URL of the GrowthOS inbound-hook API (apps/api's `/v1/hooks`, KAN-53),
# browser-exposed so the Hooks admin page can show a copy-paste receive URL.
# Falls back to a local-dev default when unset.
NEXT_PUBLIC_HOOK_API_URL=http://localhost:3001/v1/hooks

# Vault KMS key ring (KAN-29, server-only): JSON {"currentKeyId": "v1", "keys":
# {"v1": "<base64 32 bytes>"}}. Stands in for a real GCP Cloud KMS key ring
# until KAN-18 provisions the GCP project it would live in. Generate a key
# with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Required to set/rotate a shared credential's secret; leave unset otherwise.
GROWTHOS_VAULT_KEYS=
